// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Claim {
  id           String   @id @default(cuid())
  policyId     String
  amount       BigInt
  details      String   @db.VarChar(2000)
  evidenceUrls Json?    // ["https://ipfs...", ...]
  status       ClaimStatus @default(PENDING)
  createdAt    DateTime @default(now())
  deadline     DateTime?
  ledger       BigInt?

  votes     Vote[]
  policy    Policy? @relation(fields: [policyId], references: [id])  // FK to policies table (future)

  @@map("claims")
}

model Vote {
  id        String   @id @default(cuid())
  claimId   String
  voter     String   // wallet G...
  vote      Boolean  // true=approve
  ledger    BigInt
  timestamp DateTime @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@unique([claimId, voter])
  @@map("votes")
}

enum ClaimStatus {
  PENDING
  VOTING
  APPROVED
  REJECTED
  SETTLED
}

// Future
model Policy {
  id   String @id @default(cuid())
  // ...
  claims Claim[]
  @@map("policies")
}


